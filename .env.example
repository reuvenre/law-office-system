# --- Database: Neon Postgres (EU / Frankfurt) ---
# Pooled connection string from the Neon dashboard.
DATABASE_URL=

# --- Auth.js v5 ---
# Generate with: npx auth secret   (or: openssl rand -base64 32)
AUTH_SECRET=

# Google OAuth (Google Cloud Console → Credentials → OAuth client ID, Web app)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Comma-separated emails permitted to sign in (the two lawyers' Google emails)
ALLOWED_EMAILS=

# --- Storage: Vercel Blob ---
BLOB_READ_WRITE_TOKEN=

# --- Messaging providers (Phase 7 — optional until reminders go live) ---
GREEN_API_INSTANCE_ID=
GREEN_API_TOKEN=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
RESEND_API_KEY=
RESEND_FROM=office@example.com

# --- Cron protection (reminders + retainers) ---
CRON_SECRET=

# --- Payment provider webhook (integration kit) ---
PAYMENT_WEBHOOK_SECRET=

# --- Make / Drive sync (Phase 7b) ---
MAKE_WEBHOOK_URL=
# Shared bearer secret Make sends to /api/integrations/drive-callback
MAKE_CALLBACK_SECRET=
